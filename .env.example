# PostgreSQL (docker compose — lokal)
POSTGRES_USER=kompak
POSTGRES_PASSWORD=kompak
POSTGRES_DB=kompak
POSTGRES_PORT=5434

# Connection string (wajib untuk API)
# Lokal: pakai URL di atas
# Vercel + Supabase: salin POSTGRES_URL dari integrasi Supabase→Vercel
#   (atau connection string pooled dari Supabase Dashboard → Settings → Database)
DATABASE_URL=postgresql://kompak:kompak@localhost:5434/kompak

# API
API_PORT=3001
VITE_DEMO_PRODUCER_ID=ENT-DEMO-PRODUCER-001
VITE_DEMO_COOP_ID=KOP-02AFA0134DB2
VITE_DEMO_OFFTAKER_ID=OFT-DEMO-001

# --- Deploy Vercel + Supabase ---
# 1. Di Vercel Environment Variables, tambahkan:
#      DATABASE_URL = (nilai POSTGRES_URL dari integrasi Supabase)
#    Variabel NEXT_PUBLIC_SUPABASE_* tidak dipakai app ini.
# 2. Seed database Supabase (sekali):
#      DATABASE_URL="postgresql://..." npm run db:supabase-init
# 3. Redeploy, lalu verifikasi:
#      API_BASE=https://<app>.vercel.app node scripts/verify-api.mjs
